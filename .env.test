# Reference only - conftest.py sets these as real environment variables
# before any application module is imported, since Settings() is
# instantiated once at import time.
ENVIRONMENT=testing
POSTGRES_DB=app_test
JWT_SECRET_KEY=test-secret-key-for-automated-tests-only-32chars
MAX_REQUEST_SIZE_BYTES=2048
TRUSTED_HOSTS=testserver,localhost
CORS_ORIGINS=http://localhost:3000
