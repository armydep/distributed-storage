# Copy this file to .env for local development.
# Never commit a real .env file with production secrets.

# --- Application ---
APP_NAME="Distributed Storage API"
APP_VERSION="0.1.0"
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1

# --- PostgreSQL ---
# Used to build the async database URL unless DATABASE_URL is set explicitly.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Optional: overrides the values above entirely if set.
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/app

# --- JWT / Auth ---
# In production this MUST be a random secret at least 32 characters long.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=dev-secret-key-change-me-please-32chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Logging ---
LOG_LEVEL=INFO

# --- CORS (comma-separated origins, no wildcard when credentials are used) ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Trusted hosts (comma-separated, use exact hostnames in production) ---
TRUSTED_HOSTS=localhost,127.0.0.1

# --- Request limits ---
MAX_REQUEST_SIZE_BYTES=5242880

# --- Password hashing (Argon2id) ---
PASSWORD_HASH_TIME_COST=3
PASSWORD_HASH_MEMORY_COST=65536
PASSWORD_HASH_PARALLELISM=4

# --- Development seed users (Docker Compose only) ---
# Disable after creating your own accounts. The seeder refuses to run in production.
SEED_DEMO_USERS=true
SEED_USER_EMAIL=user@example.com
SEED_USER_USERNAME=user
SEED_USER_PASSWORD=UserPass123
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=AdminPass123
